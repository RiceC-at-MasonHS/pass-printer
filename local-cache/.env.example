# Clever Credentials for Headless Auth
CLEVER_USERNAME=your_username_here
CLEVER_PASSWORD=your_password_here
CLEVER_SCHOOLNAME=your_schoolname_here # e.g., "masonoh" for Mason City Schools

# Smartpass Configuration
SMARTPASS_SCHOOL_ID=2844
SMARTPASS_REGION=us-central
SCRAPER_MODE=dev # Set to 'prod' for full school sync

# Note: This file should be copied to .env and filled with real credentials.
# Do not commit .env to version control.
