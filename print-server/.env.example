# ── Printer Configuration ──────────────────────────────────────
# USB Vendor ID for the POS printer (in hex)
PRINTER_VENDOR_ID=0x0483

# USB Product ID for the POS printer (in hex)
PRINTER_PRODUCT_ID=0x5743

# ── Print Queue Configuration ──────────────────────────────────
# Maximum retry attempts for failed print jobs
PRINT_MAX_RETRIES=5

# Delay in seconds between retry attempts
PRINT_RETRY_DELAY=5

# ── Server Configuration ───────────────────────────────────────
# Server host address
SERVER_HOST=0.0.0.0

# Server port
SERVER_PORT=5000

# Enable Flask debug mode (true or false)
DEBUG=False
