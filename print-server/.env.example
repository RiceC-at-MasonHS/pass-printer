# ── Security Configuration ────────────────────────────────────
# Secret passkey required to print passes (should be strong and unique)
# Sent in the Authorization header as: Authorization: Bearer <passkey>
PRINT_PASSKEY=your-super-secret-passkey-here

# ── Printer Configuration ──────────────────────────────────────
# USB Vendor ID for the POS printer (in hex)
PRINTER_VENDOR_ID=0x0483

# USB Product ID for the POS printer (in hex)
PRINTER_PRODUCT_ID=0x5743
