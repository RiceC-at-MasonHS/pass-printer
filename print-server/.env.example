# ── Security Configuration ────────────────────────────────────
# Secret passkey required to print passes (should be strong and unique)
# Sent in the Authorization header as: Authorization: Bearer <passkey>
PRINT_PASSKEY=your-super-secret-passkey-here

# ── School Configuration ──────────────────────────────────────
# School name displayed on printed passes (can be multi-word)
SCHOOL_NAME_LINE_1=MASON HIGH
SCHOOL_NAME_LINE_2=SCHOOL

# ── Service Configuration ─────────────────────────────────────
# Name of the service for health checks and logging
SERVICE_NAME=Mason HS Hall Pass Server

# ── School Hours Configuration ─────────────────────────────────
# Timezone for school hours enforcement (e.g., US/Eastern, US/Central, US/Pacific)
TIMEZONE=US/Eastern

# School start time (24-hour format)
SCHOOL_START_HOUR=7
SCHOOL_START_MINUTE=30

# School end time (24-hour format)
SCHOOL_END_HOUR=14
SCHOOL_END_MINUTE=30


# ── Printer Configuration ──────────────────────────────────────
# USB Vendor ID for the POS printer (in hex)
PRINTER_VENDOR_ID=0x0483

# USB Product ID for the POS printer (in hex)
PRINTER_PRODUCT_ID=0x5743

# ── Print Queue Configuration ──────────────────────────────────
# Maximum retry attempts for failed print jobs
PRINT_MAX_RETRIES=5

# Delay in seconds between retry attempts
PRINT_RETRY_DELAY=5

# ── Server Configuration ───────────────────────────────────────
# Server host address
SERVER_HOST=0.0.0.0

# Server port
SERVER_PORT=5000

# Enable Flask debug mode (true or false)
DEBUG=False
